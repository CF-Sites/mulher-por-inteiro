  <section class="relative py-16 md:py-24 section-glow overflow-hidden" style="background: linear-gradient(180deg, transparent 0%, rgba(10,10,10,0.4) 50%, transparent 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      <!-- Cabeçalho -->
      <div class="text-center mb-16 reveal">
        <span class="ds-section-label font-geist">Perguntas Frequentes</span>
        <p class="text-lg text-[#888] font-geist leading-relaxed max-w-2xl mx-auto mt-6">
          Se você ainda tem alguma dúvida, aqui estão as respostas para as perguntas mais comuns:
        </p>
      </div>

      <!-- Acordeão FAQ -->
      <div class="max-w-3xl mx-auto space-y-3">

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">Quanto tempo dura a imersão?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                A imersão terá duração de aproximadamente 4 horas. É um encontro profundo, mas leve — pensado para que você consiga se desconectar da rotina e realmente viver essa experiência.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">Eu preciso ter algum tipo de experiência ou conhecimento?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                Não. Essa imersão foi criada para qualquer mulher que deseja se reconectar consigo mesma. Você não precisa ter feito terapia, cursos ou nada do tipo. Basta estar aberta para viver esse momento.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">O evento é terapêutico?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                A imersão não substitui terapia ou acompanhamento psicológico. Mas é, sim, uma experiência profunda de reconexão, reflexão e despertar emocional, conduzida com responsabilidade e acolhimento.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">O que eu devo levar?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                Apenas você. Venha com roupas confortáveis e mente aberta para viver a experiência. Todo o restante foi pensado para que você se sinta acolhida do início ao fim.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">Vai ter interação com outras mulheres?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                Sim — e esse é um dos pontos mais transformadores do encontro. Você viverá momentos de troca, conexão e partilha com outras mulheres que estão na mesma jornada que você. Nada forçado, tudo respeitando o seu tempo.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">E se eu for mais reservada?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                Está tudo bem. Você não será obrigada a falar ou se expor em nenhum momento. O ambiente é seguro, respeitoso e acolhedor — você participa no seu ritmo.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">Posso ir sozinha?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                Deve. Muitas mulheres vão sozinhas e é exatamente isso que torna a experiência ainda mais especial. Você chega sozinha… mas sai conectada.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">Como funciona a compra?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                Após garantir sua vaga, você receberá todas as informações necessárias por e-mail ou WhatsApp. Recomendamos garantir o quanto antes, pois as vagas são limitadas.
              </p>
            </div>
          </div>
        </div>

        <div class="faq-item linear-card rounded-2xl reveal">
          <button class="faq-trigger w-full flex items-center gap-3 p-6 text-left cursor-pointer">
            <i data-lucide="help-circle" class="w-5 h-5 text-orange-400 shrink-0"></i>
            <span class="font-jakarta text-lg font-medium text-white leading-tight flex-1">Posso cancelar ou transferir minha vaga?</span>
            <i data-lucide="chevron-down" class="faq-chevron w-5 h-5 text-white/40 shrink-0"></i>
          </button>
          <div class="faq-answer">
            <div class="px-6 pb-6 pl-14">
              <p class="font-geist text-[15px] text-[#888] leading-relaxed">
                Por se tratar de um evento presencial com vagas limitadas, não realizamos reembolsos. Mas você pode transferir sua vaga para outra mulher, caso não possa comparecer.
              </p>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- ================================================================
       SECTION 13: FECHAMENTO EMOCIONAL E CTA FINAL
       ================================================================ -->
  <section class="relative py-16 md:py-24 section-glow overflow-hidden" style="background: linear-gradient(180deg, transparent 0%, rgba(10,10,10,0.5) 50%, transparent 100%);">

    <!-- Ambient glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-orange-500/[0.04] blur-[100px] rounded-full pointer-events-none"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6">

      <!-- Bloco 1: A Dúvida -->
      <div class="text-center mb-16 reveal">
        <span class="ds-section-label font-geist">Última mensagem</span>
        <h2 class="text-3xl md:text-5xl font-medium text-white tracking-tight font-jakarta mt-6 mb-6 leading-[1.1]">
          Ainda estou em dúvida se<br>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-300 via-orange-400 to-amber-400" style="animation: shimmer 3s linear infinite; background-size: 200% 100%;">esse evento é para mim…</span>
        </h2>
        <div class="max-w-2xl mx-auto space-y-4">
          <p class="text-base md:text-lg text-[#888] font-geist leading-relaxed">
            Se algo dentro de você te trouxe até aqui… já é um sinal.
          </p>
          <p class="text-base md:text-lg text-[#888] font-geist leading-relaxed">
            Esse não é só um evento. É uma experiência para mulheres que sentem que precisam voltar para si.
          </p>
        </div>
      </div>

      <!-- Frase destaque -->
      <div class="text-center max-w-2xl mx-auto mb-20 reveal delay-1">
        <p class="text-xl md:text-2xl font-jakarta font-medium text-transparent bg-clip-text bg-gradient-to-r from-orange-300 via-orange-400 to-amber-400" style="animation: shimmer 3s linear infinite; background-size: 200% 100%;">
          E talvez, no fundo, você já saiba a resposta.
        </p>
      </div>

      <!-- Bloco 2: CTA Final -->
      <div class="text-center max-w-2xl mx-auto reveal delay-2">
        <span class="ds-section-label font-geist">Garanta sua vaga</span>
        <p class="text-base md:text-lg text-[#888] font-geist leading-relaxed max-w-xl mx-auto mt-6 mb-10">
          As vagas são limitadas e essa experiência foi desenhada para ser íntima, profunda e transformadora. Se você sente que esse é o seu momento… não deixe para depois.
        </p>
        <div class="flex justify-center">
          <a href="#participar" class="cta-pill hover:scale-105 transition-transform">
            <span class="cta-glow"></span>
            <span class="cta-fill"></span>
            <span class="cta-reflect"></span>
            <span class="cta-label font-geist font-medium">
              Eu quero participar
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================
       SCRIPTS
       ============================================ -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {

      /* Custom Cursor */
      const dot = document.getElementById('cursor-dot');
      const outline = document.getElementById('cursor-outline');
      let mx = 0, my = 0, ox = 0, oy = 0;

      if (window.matchMedia('(pointer: fine)').matches) {
        document.addEventListener('mousemove', (e) => {
          mx = e.clientX; my = e.clientY;
          dot.style.left = mx + 'px';
          dot.style.top = my + 'px';
        });
        (function loop() {
          ox += (mx - ox) * 0.15;
          oy += (my - oy) * 0.15;
          outline.style.left = ox + 'px';
          outline.style.top = oy + 'px';
          requestAnimationFrame(loop);
        })();
        document.querySelectorAll('a, button, [role="button"]').forEach(el => {
          el.addEventListener('mouseenter', () => document.body.classList.add('cursor-active'));
          el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-active'));
        });
      } else {
        dot.style.display = 'none';
        outline.style.display = 'none';
      }

      /* Entrance Animations */
      const contentEls = document.querySelectorAll('.content-inner .reveal-up');
      const tl = gsap.timeline({ defaults: { ease: 'power4.out' }, delay: 0.2 });

      // 1. Photo: blur-in + scale
      tl.fromTo('#heroPhoto', {
        opacity: 0, scale: 1.08, filter: 'blur(20px)'
      }, {
        opacity: 1, scale: 1, filter: 'blur(0px)',
        duration: 1.8, ease: 'power3.out'
      });

      // 2. Glow behind photo
      tl.fromTo('.photo-glow', {
        opacity: 0, scale: 0.5
      }, {
        opacity: 1, scale: 1,
        duration: 1.4, ease: 'power2.out'
      }, '-=1.4');

      // 3. Content stagger
      tl.to(contentEls, {
        opacity: 1, y: 0,
        duration: 1, stagger: 0.1,
        ease: 'power3.out'
      }, '-=1.0');

      // 4. Featured card
      tl.to('.featured-card-outer', {
        opacity: 1, y: 0,
        duration: 0.8, ease: 'back.out(1.4)'
      }, '-=0.4');

      // 5. Scroll indicator
      tl.to('.scroll-indicator', {
        opacity: 1, y: 0,
        duration: 0.6, ease: 'power2.out'
      }, '-=0.2');

      // CTA Idle Pulse
      const btn = document.getElementById('cta-btn');
      let timer;
      function resetPulse() {
        clearTimeout(timer);
        btn.classList.remove('cta-breathing');
        timer = setTimeout(() => btn.classList.add('cta-breathing'), 3500);
      }
      tl.eventCallback('onComplete', () => {
        document.addEventListener('mousemove', resetPulse);
        document.addEventListener('scroll', resetPulse);
        document.addEventListener('touchstart', resetPulse);
        resetPulse();
      });

      /* Lucide Icons init */
      lucide.createIcons();

      /* =============================================
         GSAP ScrollTrigger — H2 & section animations
         ============================================= */
      gsap.registerPlugin(ScrollTrigger);

      // Animate all section H2s (except hero which has its own)
      document.querySelectorAll('section:not(:first-of-type) h2').forEach(h2 => {
        gsap.fromTo(h2, {
          opacity: 0,
          y: 40,
          filter: 'blur(8px)'
        }, {
          opacity: 1,
          y: 0,
          filter: 'blur(0px)',
          duration: 1.2,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: h2,
            start: 'top 85%',
            toggleActions: 'play none none none'
          }
        });
      });

      // Animate .ds-section-label tags
      document.querySelectorAll('.ds-section-label').forEach(label => {
        gsap.fromTo(label, {
          opacity: 0,
          x: -20
        }, {
          opacity: 1,
          x: 0,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: label,
            start: 'top 90%',
            toggleActions: 'play none none none'
          }
        });
      });

      // Animate .linear-card items with stagger per section
      document.querySelectorAll('.grid').forEach(grid => {
        const cards = grid.querySelectorAll('.linear-card');
        if (cards.length) {
          gsap.fromTo(cards, {
            opacity: 0,
            y: 30
          }, {
            opacity: 1,
            y: 0,
            duration: 0.7,
            stagger: 0.1,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: grid,
              start: 'top 80%',
              toggleActions: 'play none none none'
            }
          });
        }
      });

      // Animate closing statements
      document.querySelectorAll('[data-animate="closing"]').forEach(el => {
        gsap.fromTo(el, {
          opacity: 0,
          scale: 0.95
        }, {
          opacity: 1,
          scale: 1,
          duration: 1,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none none'
          }
        });
      });

      /* Scroll Reveal (IntersectionObserver) — design_system.html */
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

      /* Testimonial Carousel — active card highlight */
      const slider = document.getElementById('testimonialSlider');
      const cards = slider.querySelectorAll('.testimonial-card');

      function updateActiveCard() {
        const sliderRect = slider.getBoundingClientRect();
        const centerX = sliderRect.left + sliderRect.width / 2;

        cards.forEach(card => {
          const cardRect = card.getBoundingClientRect();
          const cardCenter = cardRect.left + cardRect.width / 2;
          const dist = Math.abs(centerX - cardCenter);
          const maxDist = sliderRect.width / 2;
          // Gradual opacity based on distance from center
          const opacity = Math.max(0.35, 1 - (dist / maxDist) * 0.65);
          const scale = Math.max(0.93, 1 - (dist / maxDist) * 0.07);
          card.style.opacity = opacity;
          card.style.transform = `scale(${scale})`;
        });
      }

      slider.addEventListener('scroll', updateActiveCard);
      updateActiveCard();

      /* Auto-scroll loop — simple & clean */
      let autoIdx = 0;
      let autoInterval = null;
      let resumeTimeout = null;

      function advance() {
        autoIdx = (autoIdx + 1) % cards.length;
        // Scroll only the carousel container horizontally — never moves the page
        const card = cards[autoIdx];
        const scrollTarget = card.offsetLeft - (slider.offsetWidth / 2) + (card.offsetWidth / 2);
        slider.scrollTo({ left: scrollTarget, behavior: 'smooth' });
      }

      function start() {
        if (autoInterval) return;
        autoInterval = setInterval(advance, 4500);
      }

      function pause() {
        clearInterval(autoInterval);
        autoInterval = null;
        clearTimeout(resumeTimeout);
        resumeTimeout = setTimeout(() => {
          // Sync index with whatever card is centered now
          const cx = slider.getBoundingClientRect().left + slider.getBoundingClientRect().width / 2;
          let best = 0, bestD = Infinity;
          cards.forEach((c, i) => {
            const d = Math.abs(cx - (c.getBoundingClientRect().left + c.getBoundingClientRect().width / 2));
            if (d < bestD) { bestD = d; best = i; }
          });
          autoIdx = best;
          start();
        }, 8000);
      }

      slider.addEventListener('pointerdown', pause);
      slider.addEventListener('wheel', pause, { passive: true });
      start();

      /* Wall of Love Carousel (Section 9) — same pattern */
      const wallSlider = document.getElementById('wallSlider');
      if (wallSlider) {
        const wallCards = wallSlider.querySelectorAll('.wall-card');

        function updateWallCards() {
          const rect = wallSlider.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          wallCards.forEach(c => {
            const cRect = c.getBoundingClientRect();
            const dist = Math.abs(cx - (cRect.left + cRect.width / 2));
            const maxD = rect.width / 2;
            c.style.opacity = Math.max(0.35, 1 - (dist / maxD) * 0.65);
            c.style.transform = `scale(${Math.max(0.93, 1 - (dist / maxD) * 0.07)})`;
          });
        }

        wallSlider.addEventListener('scroll', updateWallCards);
        updateWallCards();

        // Auto-scroll
        let wIdx = 0, wInt = null, wTimeout = null;

        function wAdvance() {
          wIdx = (wIdx + 1) % wallCards.length;
          const t = wallCards[wIdx].offsetLeft - (wallSlider.offsetWidth / 2) + (wallCards[wIdx].offsetWidth / 2);
          wallSlider.scrollTo({ left: t, behavior: 'smooth' });
        }

        function wStart() { if (!wInt) wInt = setInterval(wAdvance, 4000); }

        function wPause() {
          clearInterval(wInt); wInt = null;
          clearTimeout(wTimeout);
          wTimeout = setTimeout(() => {
            const cx = wallSlider.getBoundingClientRect().left + wallSlider.getBoundingClientRect().width / 2;
            let best = 0, bestD = Infinity;
            wallCards.forEach((c, i) => {
              const d = Math.abs(cx - (c.getBoundingClientRect().left + c.getBoundingClientRect().width / 2));
              if (d < bestD) { bestD = d; best = i; }
            });
            wIdx = best;
            wStart();
          }, 8000);
        }

        wallSlider.addEventListener('pointerdown', wPause);
        wallSlider.addEventListener('wheel', wPause, { passive: true });
        // Start auto-scroll immediately
        setTimeout(wAdvance, 2000);
        wStart();
      }

      /* FAQ Accordion */
      document.querySelectorAll('.faq-trigger').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item');
          const answer = item.querySelector('.faq-answer');
          const isOpen = item.classList.contains('open');

          // Fecha todos os outros
          document.querySelectorAll('.faq-item.open').forEach(openItem => {
            if (openItem !== item) {
              openItem.classList.remove('open');
              openItem.querySelector('.faq-answer').style.maxHeight = '0';
            }
          });

          // Toggle do item clicado
          if (isOpen) {
            item.classList.remove('open');
            answer.style.maxHeight = '0';
          } else {
            item.classList.add('open');
            answer.style.maxHeight = answer.scrollHeight + 'px';
          }
        });
      });

    });
  </script>

</body>
</html>
