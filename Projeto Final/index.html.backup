  <section class="relative py-16 md:py-24 section-glow overflow-hidden" style="background: linear-gradient(180deg, transparent 0%, rgba(10,10,10,0.4) 50%, transparent 100%);">

    <!-- Ambient glows -->
    <div class="absolute top-[10%] right-0 w-[500px] h-[400px] bg-orange-500/5 blur-[100px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-[10%] left-0 w-[400px] h-[300px] bg-purple-500/[0.03] blur-[80px] rounded-full pointer-events-none"></div>

    <!-- Noise grain -->
    <div class="absolute inset-0 pointer-events-none opacity-15" style="background-image: url('https://grainy-gradients.vercel.app/noise.svg');"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-6">

      <!-- Cabeçalho -->
      <div class="text-center mb-16 reveal">
        <span class="ds-section-label font-geist">Prova Social</span>
